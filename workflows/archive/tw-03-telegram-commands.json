      "name": "Update Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 540],
      "parameters": {
        "jsCode": "const supabaseData = $input.first().json;\nconst rows = Array.isArray(supabaseData) ? supabaseData : [supabaseData];\nconst row = rows[0];\nconst drafts = typeof row.drafts === 'string' ? JSON.parse(row.drafts) : row.drafts;\nconst { tweetNum, newText, hoje } = $('Parse & Route').item.json;\n\nconst updated = drafts.map(d => d.id === tweetNum ? { ...d, texto: newText, char_count: newText.length } : d);\nreturn [{ json: { supabaseId: row.id, drafts: updated, tweetNum, newText, hoje } }];"
