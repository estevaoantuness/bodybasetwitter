  "nodes": [
    {
      "id": "node-telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [200, 300],
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "TELEGRAM_CRED_ID",
          "name": "Telegram — Clawd HQ"
        }
      }
    },
    {
      "id": "node-filter-topic",
      "name": "Filter Topic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300],
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nif (!msg) return [];\nif (msg.message_thread_id !== 16) return [];\nreturn [$input.first()];"
      }
    },
    {
      "id": "node-parse-route",
      "name": "Parse & Route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 300],
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst caption = (msg.caption || '').trim();\nconst text = (msg.text || '').trim();\nconst capLower = caption.toLowerCase();\nconst textLower = text.toLowerCase();\n\nlet route, tweetNum, newText, fileId;\n\nif (msg.photo && capLower.startsWith('aprova')) {\n  const match = caption.match(/aprova\\s+(\\d+)/i);\n  tweetNum = match ? parseInt(match[1]) : 1;\n  const photos = msg.photo;\n  fileId = photos[photos.length - 1].file_id;\n  route = 'photo_approve';\n} else if (!msg.photo && textLower.startsWith('aprova')) {\n  const match = text.match(/aprova\\s+(\\d+)/i);\n  tweetNum = match ? parseInt(match[1]) : 1;\n  route = 'text_approve';\n} else if (textLower.startsWith('edita')) {\n  const match = text.match(/edita\\s+(\\d+):\\s*(.+)/i);\n  tweetNum = match ? parseInt(match[1]) : 1;\n  newText = match ? match[2].trim() : text;\n  route = 'edit';\n} else if (textLower === 'ignore') {\n  route = 'ignore';\n} else {\n  route = 'unknown';\n}\n\nconst hoje = new Date().toISOString().split('T')[0];\nreturn [{ json: { msg, route, tweetNum, newText, fileId, hoje, chatId: msg.chat.id, threadId: msg.message_thread_id } }];"
      }
    },
    {
      "id": "node-command-switch",
      "name": "Command Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [860, 300],
      "parameters": {
        "mode": "expression",
        "output": "={{ $json.route === 'photo_approve' ? 0 : $json.route === 'text_approve' ? 1 : $json.route === 'edit' ? 2 : 3 }}"
      }
    },
    {
      "id": "node-store-photo-context",
      "name": "Store Photo Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 60],
      "parameters": {
        "jsCode": "return [{ json: {\n  fileId: $json.fileId,\n  tweetNum: $json.tweetNum,\n  hoje: $json.hoje,\n  chatId: $json.chatId,\n  threadId: $json.threadId\n}}];"
      }
    },
