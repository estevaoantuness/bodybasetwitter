    {
      "id": "node-build-photo-tweet-body",
      "name": "Build Photo Tweet Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2100, 60],
      "parameters": {
        "jsCode": "const mediaId = $('Upload to Twitter Media').item.json.media_id_string;\nconst supabaseData = $('Fetch Draft for Photo Branch').item.json;\nconst rows = Array.isArray(supabaseData) ? supabaseData : [supabaseData];\nconst row = rows[0];\nconst drafts = typeof row.drafts === 'string' ? JSON.parse(row.drafts) : row.drafts;\nconst tweetNum = $('Parse & Route').item.json.tweetNum;\nconst draft = drafts.find(d => d.id === tweetNum) || drafts[0];\n\nreturn [{ json: {\n  tweetBody: { text: draft.texto, media: { media_ids: [mediaId] } },\n  draftText: draft.texto,\n  tweetNum,\n  chatId: $('Parse & Route').item.json.chatId\n}}];"
      }
    },
