    {
      "id": "node-build-ignore-message",
      "name": "Build Ignore Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 780],
      "parameters": {
        "jsCode": "const route = $('Parse & Route').item.json.route;\nconst chatId = $('Parse & Route').item.json.chatId;\nconst msg = route === 'ignore'\n  ? '❌ Rascunhos de hoje descartados.'\n  : '❓ Comando não reconhecido.\\n\\nUse:\\n• aprova N\\n• [foto] + caption \"aprova N\"\\n• edita N: texto\\n• ignore';\nreturn [{ json: { text: msg, chatId } }];"
      }
